{
  "name": "reading-companion",
  "version": "0.96.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "node scripts/build.mjs",
    "package:chrome": "wxt zip -b chrome --mv3",
    "package:firefox": "wxt zip -b firefox --mv2",
    "package:all": "npm run package:chrome && npm run package:firefox",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && npm run lint:unused",
    "lint:unused": "knip --include files",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:cliproxy": "playwright test tests/e2e/cliproxy-gemini-smoke.spec.ts",
    "test:e2e:long": "playwright test tests/e2e/full-state-machine-long.spec.ts --workers=2",
    "check:size": "node scripts/check-size.mjs",
    "check": "npm run typecheck && npm run lint && npm run check:size && npm run test && npm run build"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.74.0",
    "@wxt-dev/module-react": "^1.2.2",
    "agent-browser": "^0.27.0",
    "fake-indexeddb": "^6.2.5",
    "idb": "^8.0.3",
    "lucide-react": "^0.554.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "wxt": "^0.20.26",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/chrome": "^0.1.34",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser": "^4.1.6",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9.39.1",
    "eslint-plugin-jsdoc": "^61.4.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unicorn": "^62.0.0",
    "jsdom": "^27.2.0",
    "knip": "^6.14.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.1.6"
  }
}
